#NAME "Test Alternation Dictionary"
#INDEX_LANGUAGE "English"
#CONTENTS_LANGUAGE "Spanish"

colour{/}color
	[m1][b]colour / color[/b][/m]
	[m2][trn]color [p]m[/p][/trn][/m]

go(es)
	[m1][b]go[/b] [c green]/ɡoʊ/[/c][/m]
	[m1][p]verb[/p][/m]
	[m2][trn]ir[/trn][/m]

favo{u/}rite
	[m1][b]favourite / favorite[/b][/m]
	[m2][trn]favorito [p]adj[/p][/trn][/m]

do(es)n't
	[m1][b]don't / doesn't[/b][/m]
	[m2][trn]no (negación)[/trn][/m]

real{ize/ise}
	[m1][b]realize / realise[/b][/m]
	[m2][trn]darse cuenta[/trn][/m]

\{curly\}
	[m1][b]{curly}[/b][/m]
	[m2][trn]literal curly braces in headword[/trn][/m]

\(round\)
	[m1][b](round)[/b][/m]
	[m2][trn]literal round brackets in headword[/trn][/m]
